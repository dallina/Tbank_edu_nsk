print("Введите начало и конец диапазона:")
beginning, end = map(int, input().split())
if beginning > end:
    print("Ошибка: начало диапазона должно быть меньше конца")
    beginning, end = end, beginning
n1, n2 = 0, 1
nums = []

while n1 <= end:
    if n1 >= beginning:
        nums.append(n1)
    n1, n2 = n2, n1 + n2

if nums:
    print(" ".join(map(str, nums)))
else:
    print("В заданном диапазоне нет чисел Фибоначчи")
